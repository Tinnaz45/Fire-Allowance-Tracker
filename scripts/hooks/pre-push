#!/usr/bin/env bash
# pre-push — Fire Allowance Tracker
#
# Blocks any direct push to origin/main unless the current local branch is actually main.
# This prevents "Everything up-to-date" false-positive deployments caused by:
#   - failed git checkout main (left on wrong branch)
#   - accidental push from dev or a detached HEAD
#
# Normal dev pushes (to origin/dev or any other remote/branch) pass through unaffected.
#
# To bypass in a genuine emergency: git push --no-verify
# To reinstall after clone: npm install (runs scripts/install-hooks.mjs via "prepare")

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

REMOTE="$1"
# $2 is the URL; not needed here

# Only guard pushes to 'origin'
if [ "$REMOTE" != "origin" ]; then
  exit 0
fi

# Read the refs being pushed from stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  # Only guard pushes targeting refs/heads/main
  if [ "$remote_ref" = "refs/heads/main" ]; then
    CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "")

    if [ "$CURRENT_BRANCH" != "main" ]; then
      echo ""
      echo -e "${RED}✗ pre-push: Push to origin/main BLOCKED${NC}"
      echo ""
      echo -e "  Current branch : ${YELLOW}${CURRENT_BRANCH:-<detached HEAD>}${NC}"
      echo -e "  Required branch: main"
      echo ""
      echo "  Pushing to main from the wrong branch risks a silent false-success."
      echo "  Use the safe release workflow instead:"
      echo ""
      echo "    npm run release"
      echo ""
      echo "  Emergency bypass (use sparingly):"
      echo "    git push --no-verify"
      echo ""
      exit 1
    fi
  fi
done

exit 0
